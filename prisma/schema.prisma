generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum WorkType {
  REMOTE
  HYBRID
  ON_SITE
}

enum PreferredTone {
  FORMAL
  FRIENDLY
  CONFIDENT
  CONCISE
}

enum ApplicationStatus {
  DRAFT
  APPLIED
  IN_REVIEW
  INTERVIEW_SCHEDULED
  OFFER_RECEIVED
  REJECTED
  WITHDRAWN
}

enum DocumentType {
  COVER_LETTER
  FORM_FILL_JSON
}

enum EventType {
  STATUS_CHANGED
  DOCUMENT_GENERATED
  NOTE_ADDED
  INTERVIEW_SCHEDULED
  OFFER_RECEIVED
  REJECTED
}

enum SuggestionPriority {
  HIGH
  MEDIUM
  LOW
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  resumes      Resume[]
  preferences  UserPreferences?
  matchScores  JobMatchScore[]
  applications Application[]

  @@map("users")
}

model Resume {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  rawText    String?  @map("raw_text") @db.LongText
  parsedJson Json?    @map("parsed_json")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchScores  JobMatchScore[]
  applications Application[]
  documents    GeneratedDocument[]

  @@index([userId])
  @@map("resumes")
}

model UserPreferences {
  id              String        @id @default(cuid())
  userId          String        @unique @map("user_id")
  targetRoles     Json          @map("target_roles")
  targetLocations Json          @map("target_locations")
  minSalary       Int?          @map("min_salary")
  maxSalary       Int?          @map("max_salary")
  workType        WorkType?     @map("work_type")
  preferredTone   PreferredTone @default(CONFIDENT) @map("preferred_tone")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model JobOffer {
  id           String   @id @default(cuid())
  title        String
  company      String
  location     String?
  description  String   @db.LongText
  requirements String?  @db.LongText
  salaryRange  String?  @map("salary_range")
  jobUrl       String   @unique @map("job_url")
  source       String
  scrapedAt    DateTime @default(now()) @map("scraped_at")
  isActive     Boolean  @default(true) @map("is_active")

  matchScores  JobMatchScore[]
  applications Application[]

  @@index([isActive])
  @@index([source])
  @@fulltext([title, company, description])
  @@map("job_offers")
}

model JobMatchScore {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  jobOfferId       String   @map("job_offer_id")
  resumeId         String   @map("resume_id")
  score            Float
  matchDetailsJson Json     @map("match_details_json")
  suggestions      Json?    @map("suggestions")
  computedAt       DateTime @default(now()) @map("computed_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobOffer JobOffer @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  resume   Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([userId, jobOfferId, resumeId])
  @@index([userId, score])
  @@map("job_match_scores")
}

model Application {
  id         String            @id @default(cuid())
  userId     String            @map("user_id")
  jobOfferId String            @map("job_offer_id")
  resumeId   String            @map("resume_id")
  status     ApplicationStatus @default(DRAFT)
  appliedAt  DateTime?         @map("applied_at")
  notes      String?           @db.Text

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobOffer JobOffer @relation(fields: [jobOfferId], references: [id])
  resume   Resume   @relation(fields: [resumeId], references: [id])

  documents GeneratedDocument[]
  events    ApplicationEvent[]

  @@index([userId, status])
  @@index([jobOfferId])
  @@map("applications")
}

model GeneratedDocument {
  id            String       @id @default(cuid())
  applicationId String       @map("application_id")
  resumeId      String?      @map("resume_id")
  type          DocumentType
  content       String       @db.LongText
  fileUrl       String?      @map("file_url")
  createdAt     DateTime     @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  resume      Resume?     @relation(fields: [resumeId], references: [id])

  @@index([applicationId])
  @@map("generated_documents")
}

model ApplicationEvent {
  id            String    @id @default(cuid())
  applicationId String    @map("application_id")
  eventType     EventType @map("event_type")
  detailsJson   Json?     @map("details_json")
  createdAt     DateTime  @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
  @@map("application_events")
}
