generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum WorkType {
  REMOTE
  HYBRID
  ON_SITE
}

enum PreferredTone {
  FORMAL
  FRIENDLY
  CONFIDENT
  CONCISE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  phone        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  resumes     Resume[]
  preferences UserPreferences?

  @@map("users")
}

model Resume {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  rawText    String?  @map("raw_text") @db.LongText
  parsedJson Json?    @map("parsed_json")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions ResumeVersion[]

  @@index([userId])
  @@map("resumes")
}

model ResumeVersion {
  id            String   @id @default(cuid())
  resumeId      String   @map("resume_id")
  resume        Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobUrl        String?  @map("job_url")
  jobText       String?  @map("job_text") @db.LongText
  optimizedJson Json     @map("optimized_json")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([resumeId])
  @@map("resume_versions")
}

model UserPreferences {
  id              String        @id @default(cuid())
  userId          String        @unique @map("user_id")
  targetRoles     Json          @map("target_roles")
  targetLocations Json          @map("target_locations")
  minSalary       Int?          @map("min_salary")
  maxSalary       Int?          @map("max_salary")
  workType        WorkType?     @map("work_type")
  preferredTone   PreferredTone @default(CONFIDENT) @map("preferred_tone")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
